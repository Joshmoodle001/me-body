# Me Body — Environment Variables (copy to .env.local)

# USDA Food Data Central (free — https://fdc.nal.usda.gov/api-key-signup.html)
USDA_FDC_API_KEY=DEMO_KEY

# Open Food Facts (no auth required, User-Agent recommended)
OPEN_FOOD_FACTS_USER_AGENT=MeBody/0.1

# Supabase (free tier — https://supabase.com)
# Create a project, then copy the URL and anon key from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
