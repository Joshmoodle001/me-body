# Me Body — Environment Variables (copy to .env.local)

# USDA Food Data Central (free — https://fdc.nal.usda.gov/api-key-signup.html)
USDA_FDC_API_KEY=DEMO_KEY

# Open Food Facts (no auth required, User-Agent recommended)
OPEN_FOOD_FACTS_USER_AGENT=MeBody/0.1

# Supabase (free tier — https://supabase.com)
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the Project URL and anon/public key below
# 4. IMPORTANT: In Authentication > Settings, disable "Confirm email" for simple signup
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
