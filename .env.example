# Me Body Environment Variables
# Copy this to .env.local and fill in your values

NEXT_PUBLIC_APP_NAME="Me Body"

# Open Food Facts (no auth required for read)
OPEN_FOOD_FACTS_BASE_URL="https://world.openfoodfacts.org"
OPEN_FOOD_FACTS_USER_AGENT="MeBody/0.1 (founder@example.com)"

# USDA FoodData Central
# Use DEMO_KEY for initial prototyping (limited to 1,000 requests/hour)
# Get a full key at https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY="DEMO_KEY"

# Supabase (optional - only for sync/auth features)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
